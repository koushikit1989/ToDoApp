<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Taskco-TO-DO-Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --grad-start: #667eea;
            --grad-end:   #764ba2;
        }
        body {
            background: #f0f2f5;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, system-ui, sans-serif;
        }
        /* ── Navbar ─────────────────────────────────── */
        .navbar {
            background: linear-gradient(135deg, var(--grad-start) 0%, var(--grad-end) 100%) !important;
            box-shadow: 0 2px 16px rgba(102,126,234,.4);
        }
        .navbar-brand {
            font-weight: 800;
            font-size: 1.15rem;
            letter-spacing: .4px;
        }
        .btn-nav-logout {
            background: rgba(255,255,255,.15);
            color: #fff;
            border: 1px solid rgba(255,255,255,.25);
            font-size: .82rem;
            transition: background .2s;
        }
        .btn-nav-logout:hover { background: rgba(255,255,255,.25); color: #fff; }
        #navAvatar {
            width: 32px; height: 32px;
            background: rgba(255,255,255,.22);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: .85rem; font-weight: 700; color: #fff;
        }
        /* ── Sidebar ─────────────────────────────────── */
        .sidebar {
            min-height: calc(100vh - 56px);
            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 55%, #0f3460 100%);
            border-right: none;
            box-shadow: 4px 0 24px rgba(0,0,0,.14);
        }
        .sidebar-section-label {
            color: rgba(255,255,255,.35);
            font-size: .65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            padding: 0 14px 6px;
            display: block;
        }
        .sidebar .nav-link {
            color: rgba(255,255,255,.65);
            border-radius: 10px;
            margin-bottom: 3px;
            padding: 10px 14px;
            font-weight: 500;
            font-size: .88rem;
            transition: all .2s ease;
        }
        .sidebar .nav-link i { width: 20px; font-size: .95rem; }
        .sidebar .nav-link.active {
            background: linear-gradient(135deg, rgba(102,126,234,.65) 0%, rgba(118,75,162,.65) 100%);
            color: #fff;
            box-shadow: 0 4px 14px rgba(102,126,234,.3);
        }
        .sidebar .nav-link:hover:not(.active) {
            background: rgba(255,255,255,.08);
            color: #fff;
            transform: translateX(3px);
        }
        .sidebar hr { border-color: rgba(255,255,255,.1); margin: 8px 14px; }
        /* ── Cards ───────────────────────────────────── */
        .card {
            border: none;
            box-shadow: 0 2px 16px rgba(0,0,0,.06);
            border-radius: 16px;
        }
        .card-header {
            border-radius: 16px 16px 0 0 !important;
            border-bottom: 1px solid rgba(0,0,0,.05);
        }
        /* ── Stat cards ──────────────────────────────── */
        .stat-card { border-radius: 16px !important; overflow: hidden; transition: transform .2s, box-shadow .2s; }
        .stat-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(0,0,0,.14); }
        .stat-card-blue   { background: linear-gradient(135deg,#667eea,#764ba2); color:#fff; }
        .stat-card-green  { background: linear-gradient(135deg,#11998e,#38ef7d); color:#fff; }
        .stat-card-orange { background: linear-gradient(135deg,#f7971e,#ffd200); color:#1a1a1a; }
        .stat-card-red    { background: linear-gradient(135deg,#f85032,#e73827); color:#fff; }
        .stat-card .stat-icon { font-size: 2.2rem; opacity: .22; line-height: 1; }
        .stat-card .stat-label { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .9px; opacity: .82; }
        .stat-card .stat-value { font-size: 2.1rem; font-weight: 800; line-height: 1.2; margin-top: 4px; }
        /* ── Badges ──────────────────────────────────── */
        .badge { font-weight: 600; font-size: .72em; padding: 5px 9px; border-radius: 6px; }
        .badge-priority-low    { background: linear-gradient(135deg,#11998e,#38ef7d); color:#fff; }
        .badge-priority-medium { background: linear-gradient(135deg,#f7971e,#ffd200); color:#1a1a1a; }
        .badge-priority-high   { background: linear-gradient(135deg,#f85032,#e73827); color:#fff; }
        .badge-status-pending    { background: #e9ecef; color: #495057; }
        .badge-status-inprogress { background: linear-gradient(135deg,#4776E6,#8E54E9); color:#fff; }
        .badge-status-completed  { background: linear-gradient(135deg,#11998e,#38ef7d); color:#fff; }
        /* ── Tables ──────────────────────────────────── */
        .table > :not(caption) > * > * { padding: .75rem 1rem; }
        .table thead tr { background: #f8f9ff; }
        .table-hover tbody tr:hover { background: rgba(102,126,234,.045); }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/dashboard"><i class="bi bi-check2-square me-2"></i>Taskco-TO-DO-Manager</a>
            <div class="d-flex align-items-center ms-auto gap-2" id="navUser" style="display:none!important">
                <div id="navAvatar"></div>
                <span class="text-white small fw-semibold" id="navUserName"></span>
                <button class="btn btn-sm btn-nav-logout ms-1" onclick="logout()">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </button>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-2 d-none d-md-block sidebar py-3 px-2" id="sidebar" style="display:none!important">
                <span class="sidebar-section-label">Main Menu</span>
                <ul class="nav flex-column mb-2">
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["Page"]?.ToString() == "Dashboard" ? "active" : "")" href="/dashboard">
                            <i class="bi bi-speedometer2 me-2"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["Page"]?.ToString() == "Tasks" ? "active" : "")" href="/tasks">
                            <i class="bi bi-list-task me-2"></i>My Tasks
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["Page"]?.ToString() == "Projects" ? "active" : "")" href="/projects">
                            <i class="bi bi-folder2-open me-2"></i>Projects
                        </a>
                    </li>
                </ul>
                <hr />
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link" href="#" onclick="logout(); return false;">
                            <i class="bi bi-box-arrow-left me-2"></i>Sign Out
                        </a>
                    </li>
                </ul>
            </nav>

            <main class="col-md-10 ms-sm-auto px-4 py-3" id="mainContent">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const API = '';

        function getToken() { return localStorage.getItem('access_token'); }
        function getUser()  { return JSON.parse(localStorage.getItem('user_info') || 'null'); }

        function logout() {
            localStorage.removeItem('access_token');
            localStorage.removeItem('refresh_token');
            localStorage.removeItem('user_info');
            window.location.href = '/login';
        }

        async function apiFetch(path, options = {}) {
            const token = getToken();
            const headers = { 'Content-Type': 'application/json', ...(options.headers || {}) };
            if (token) headers['Authorization'] = `Bearer ${token}`;
            const res = await fetch(API + path, { ...options, headers });
            if (res.status === 401) { logout(); return null; }
            return res;
        }

        (function () {
            const user = getUser();
            const token = getToken();
            const isAuthPage = ['/login', '/register', '/'].includes(window.location.pathname);
            if (token && user) {
                document.getElementById('navUser').style.display = 'flex';
                document.getElementById('navUserName').textContent = user.fullName;
                const av = document.getElementById('navAvatar');
                if (av) av.textContent = (user.fullName || '?').charAt(0).toUpperCase();
                document.getElementById('sidebar').style.display = 'block';
                document.getElementById('mainContent').className = 'col-md-10 ms-sm-auto px-4 py-3';
            } else if (!isAuthPage) {
                window.location.href = '/login';
            } else {
                document.getElementById('sidebar').style.display = 'none';
                document.getElementById('mainContent').className = 'col-12 px-4 py-3';
            }
        })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
