@page
@model TasksPageModel
@{
    ViewData["Title"] = "My Tasks";
    ViewData["Page"] = "Tasks";
}

<style>
    /* ── Page banner ──────────────────────────────── */
    .page-banner {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 16px;
        padding: 18px 22px;
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 20px;
        box-shadow: 0 4px 22px rgba(102,126,234,.38);
        color: #fff;
    }
    .page-banner h4 { font-size: 16px; font-weight: 800; margin: 0 0 3px; color: #fff; }
    .page-banner p  { font-size: 12px; opacity: .82; margin: 0; }
    .btn-banner {
        background: rgba(255,255,255,.18); color: #fff;
        border: 1px solid rgba(255,255,255,.3);
        border-radius: 8px; padding: 7px 15px;
        font-size: 12px; font-weight: 700;
        cursor: pointer; display: flex; align-items: center; gap: 5px;
        white-space: nowrap; flex-shrink: 0;
        transition: background .18s;
    }
    .btn-banner:hover { background: rgba(255,255,255,.28); }

    /* ── Filter bar ───────────────────────────────── */
    .filter-header {
        font-size: 11px; font-weight: 700; text-transform: uppercase;
        letter-spacing: .9px; color: #7b82a0;
        display: flex; align-items: center; gap: 6px;
        padding: 14px 18px 10px; border-bottom: 1px solid rgba(0,0,0,.05);
    }
    .filter-body { padding: 12px 18px; }
    .form-select-sm, .form-control-sm {
        border-radius: 8px; border: 1px solid #e0e3ef;
        font-size: 12.5px; transition: border-color .18s, box-shadow .18s;
    }
    .form-select-sm:focus, .form-control-sm:focus {
        border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,.14);
        outline: none;
    }
    .btn-clear {
        background: #f0f2f5; color: #495057;
        border: 1px solid #dee2e6; border-radius: 8px;
        font-size: 12px; font-weight: 600;
        width: 100%; padding: 5px 0; cursor: pointer;
        transition: all .15s;
    }
    .btn-clear:hover { background: rgba(102,126,234,.08); color: #667eea; border-color: #667eea; }

    /* ── Table action buttons ─────────────────────── */
    .btn-act {
        width: 30px; height: 30px; border-radius: 8px; border: none;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 13px; cursor: pointer; transition: all .15s;
    }
    .btn-act-edit   { background: rgba(102,126,234,.1); color: #667eea; }
    .btn-act-edit:hover   { background: rgba(102,126,234,.22); }
    .btn-act-delete { background: rgba(231,56,39,.1); color: #e73827; }
    .btn-act-delete:hover { background: rgba(231,56,39,.2); }

    /* ── Pagination ───────────────────────────────── */
    .pager { padding: 12px 20px; display: flex; justify-content: space-between; align-items: center; }
    .pager small { font-size: 12px; color: #7b82a0; }
    .btn-page {
        background: #f0f2f5; border: 1px solid #dee2e6; border-radius: 7px;
        font-size: 12px; font-weight: 600; color: #495057;
        padding: 5px 12px; cursor: pointer; transition: all .15s;
    }
    .btn-page:disabled { opacity: .38; cursor: default; }
    .btn-page:not(:disabled):hover { background: rgba(102,126,234,.1); color: #667eea; border-color: #667eea; }

    /* ── Modals ───────────────────────────────────── */
    .modal-content  { border: none; border-radius: 16px; box-shadow: 0 8px 40px rgba(0,0,0,.18); }
    .modal-header   { background: linear-gradient(135deg,#667eea,#764ba2); border-radius: 16px 16px 0 0; }
    .modal-title    { color: #fff; font-size: 15px; font-weight: 700; }
    .modal .btn-primary {
        background: linear-gradient(135deg,#667eea,#764ba2);
        border: none; border-radius: 8px; font-weight: 700;
    }
    .modal .btn-primary:disabled { opacity: .6; }
    .modal .btn-danger { background: linear-gradient(135deg,#f85032,#e73827); border: none; border-radius: 8px; font-weight: 700; }
    .modal .btn-secondary { border-radius: 8px; }
    .modal .form-control, .modal .form-select {
        border-radius: 8px; border-color: #e0e3ef;
        font-size: 13.5px;
    }
    .modal .form-control:focus, .modal .form-select:focus {
        border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,.14);
    }
    .modal .form-label { font-size: 12px; font-weight: 700; color: #5a6072; text-transform: uppercase; letter-spacing: .6px; }
    .modal-footer { border-top: 1px solid rgba(0,0,0,.06); }
    .modal-alert { border-radius: 8px; font-size: 13px; }

    /* ── Inline badges ────────────────────────────── */
    .badge-proj   { background: linear-gradient(135deg,#4776E6,#8E54E9); color:#fff; }
    .badge-overdue { background: linear-gradient(135deg,#f85032,#e73827); color:#fff; font-size:.68em; }
    .no-project-label { color: #adb5bd; font-size: 12px; }
</style>

<!-- Page banner -->
<div class="page-banner mb-4">
    <div>
        <h4>My Tasks</h4>
        <p>Create, filter and track all your tasks</p>
    </div>
    <button class="btn-banner" onclick="openCreateModal()">
        <i class="bi bi-plus-lg"></i>New Task
    </button>
</div>

<!-- Filters -->
<div class="card mb-3">
    <div class="filter-header">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#667eea" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
        Filters
    </div>
    <div class="filter-body">
        <div class="row g-2">
            <div class="col-md-3">
                <select class="form-select form-select-sm" id="filterStatus" onchange="loadTasks()">
                    <option value="">All Statuses</option>
                    <option value="0">Pending</option>
                    <option value="1">In Progress</option>
                    <option value="2">Completed</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" id="filterPriority" onchange="loadTasks()">
                    <option value="">All Priorities</option>
                    <option value="1">Low</option>
                    <option value="2">Medium</option>
                    <option value="3">High</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select form-select-sm" id="filterProject" onchange="loadTasks()">
                    <option value="">All Projects</option>
                </select>
            </div>
            <div class="col-md-2">
                <input type="text" class="form-control form-control-sm" id="filterSearch" placeholder="Search…" oninput="debounceLoad()" />
            </div>
            <div class="col-md-2">
                <button class="btn-clear" onclick="clearFilters()">Clear filters</button>
            </div>
        </div>
    </div>
</div>

<!-- Task list -->
<div class="card">
    <div id="tasksLoading" class="text-center p-4 text-muted">
        <div class="spinner-border spinner-border-sm me-2" style="color:#667eea"></div>Loading…
    </div>
    <div id="tasksEmpty" class="text-center text-muted p-4 d-none">
        <i class="bi bi-inbox fs-2 d-block mb-2"></i>No tasks found.
    </div>
    <div class="table-responsive d-none" id="tasksTableWrap">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Title</th>
                    <th>Project</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Due Date</th>
                    <th class="pe-4">Actions</th>
                </tr>
            </thead>
            <tbody id="tasksBody"></tbody>
        </table>
    </div>
    <div class="d-none" id="pagination">
        <div class="pager">
            <small id="pageInfo"></small>
            <div class="d-flex gap-2">
                <button class="btn-page" id="prevBtn" onclick="changePage(-1)">
                    <i class="bi bi-chevron-left me-1"></i>Previous
                </button>
                <button class="btn-page" id="nextBtn" onclick="changePage(1)">
                    Next<i class="bi bi-chevron-right ms-1"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Create / Edit Modal -->
<div class="modal fade" id="taskModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">New Task</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="modalAlert" class="alert alert-danger modal-alert d-none"></div>
                <form id="taskForm">
                    <input type="hidden" id="taskId" />
                    <div class="mb-3">
                        <label class="form-label">Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="taskTitle" maxlength="300" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" id="taskDesc" rows="2" maxlength="2000"></textarea>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label">Priority</label>
                            <select class="form-select" id="taskPriority">
                                <option value="1">Low</option>
                                <option value="2">Medium</option>
                                <option value="3">High</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Status</label>
                            <select class="form-select" id="taskStatus">
                                <option value="0">Pending</option>
                                <option value="1">In Progress</option>
                                <option value="2">Completed</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Project</label>
                        <select class="form-select" id="taskProject">
                            <option value="">— No Project —</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Due Date <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="taskDueDate" required />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="saveBtn" onclick="saveTask()">
                    <span id="saveSpinner" class="spinner-border spinner-border-sm d-none me-1"></span>
                    Save Task
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete confirmation modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Task</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="font-size:13.5px">
                Are you sure you want to delete this task? This action cannot be undone.
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger btn-sm" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let currentPage = 1;
    const pageSize = 10;
    let totalCount = 0;
    let debounceTimer = null;
    let allProjects = [];
    const taskStore = {};

    function escHtml(s) {
        return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }

    function buildProjectOptions(select, leadLabel) {
        select.innerHTML = '';
        const lead = document.createElement('option');
        lead.value = '';
        lead.textContent = leadLabel;
        select.appendChild(lead);
        for (const p of allProjects) {
            const opt = document.createElement('option');
            opt.value = p.id;
            opt.textContent = p.projectName + (p.isActive ? '' : ' (Inactive)');
            select.appendChild(opt);
        }
    }

    function showFormErrors(el, data) {
        el.innerHTML = '';
        if (data.errors?.length) {
            const ul = document.createElement('ul');
            ul.style.cssText = 'margin:0;padding-left:1.2em';
            data.errors.forEach(msg => {
                const li = document.createElement('li');
                li.textContent = msg;
                ul.appendChild(li);
            });
            el.appendChild(ul);
        } else {
            el.textContent = data.message || 'An error occurred.';
        }
        el.classList.remove('d-none');
    }

    const priorityBadge = p => `<span class="badge badge-priority-${p.toLowerCase()}">${escHtml(p)}</span>`;
    const statusBadge = s => {
        const cls = s === 'Pending' ? 'pending' : s === 'InProgress' ? 'inprogress' : 'completed';
        const label = s === 'InProgress' ? 'In Progress' : s;
        return `<span class="badge badge-status-${cls}">${escHtml(label)}</span>`;
    };

    async function loadProjects() {
        const res = await apiFetch('/api/projects');
        if (!res) return;
        const data = await res.json();
        allProjects = data.data || [];

        const filterSel = document.getElementById('filterProject');
        const modalSel  = document.getElementById('taskProject');
        buildProjectOptions(filterSel, 'All Projects');
        buildProjectOptions(modalSel,  '— No Project —');
    }

    function debounceLoad() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => loadTasks(), 400);
    }

    function clearFilters() {
        document.getElementById('filterStatus').value   = '';
        document.getElementById('filterPriority').value = '';
        document.getElementById('filterProject').value  = '';
        document.getElementById('filterSearch').value   = '';
        currentPage = 1;
        loadTasks();
    }

    async function loadTasks() {
        document.getElementById('tasksLoading').classList.remove('d-none');
        document.getElementById('tasksTableWrap').classList.add('d-none');
        document.getElementById('tasksEmpty').classList.add('d-none');
        document.getElementById('pagination').classList.add('d-none');

        const status    = document.getElementById('filterStatus').value;
        const priority  = document.getElementById('filterPriority').value;
        const projectId = document.getElementById('filterProject').value;
        const search    = document.getElementById('filterSearch').value;

        let url = `/api/tasks/filter?pageNumber=${currentPage}&pageSize=${pageSize}`;
        if (status)    url += `&status=${status}`;
        if (priority)  url += `&priority=${priority}`;
        if (projectId) url += `&projectId=${projectId}`;
        if (search)    url += `&searchTerm=${encodeURIComponent(search)}`;

        const res = await apiFetch(url);
        if (!res) return;
        const data = await res.json();
        const paged = data.data;

        document.getElementById('tasksLoading').classList.add('d-none');
        totalCount = paged.totalCount;

        const tbody = document.getElementById('tasksBody');
        tbody.innerHTML = '';

        if (!paged.items || paged.items.length === 0) {
            document.getElementById('tasksEmpty').classList.remove('d-none');
            return;
        }

        for (const t of paged.items) taskStore[t.id] = t;

        tbody.innerHTML = paged.items.map(t => `
            <tr>
                <td class="ps-4">
                    <div class="fw-semibold">${escHtml(t.title)}</div>
                    ${t.description ? `<small class="text-muted">${escHtml(t.description.substring(0,60))}${t.description.length>60?'…':''}</small>` : ''}
                    ${t.isOverdue ? '<span class="badge badge-overdue ms-1">Overdue</span>' : ''}
                </td>
                <td>
                    ${t.projectName
                        ? `<span class="badge badge-proj">${escHtml(t.projectName)}</span>`
                        : '<span class="no-project-label">—</span>'}
                </td>
                <td>${priorityBadge(t.priority)}</td>
                <td>${statusBadge(t.status)}</td>
                <td class="text-muted" style="font-size:13px">${new Date(t.dueDate).toLocaleDateString()}</td>
                <td class="pe-4">
                    <button class="btn-act btn-act-edit me-1" onclick="openEditModal('${t.id}')">
                        <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn-act btn-act-delete" onclick="confirmDelete('${t.id}')">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            </tr>`).join('');

        document.getElementById('tasksTableWrap').classList.remove('d-none');

        const totalPages = Math.ceil(totalCount / pageSize);
        if (totalPages > 1) {
            document.getElementById('pageInfo').textContent = `Page ${currentPage} of ${totalPages} (${totalCount} tasks)`;
            document.getElementById('prevBtn').disabled = currentPage <= 1;
            document.getElementById('nextBtn').disabled = currentPage >= totalPages;
            document.getElementById('pagination').classList.remove('d-none');
        }
    }

    function changePage(delta) {
        currentPage += delta;
        loadTasks();
    }

    function openCreateModal() {
        document.getElementById('modalTitle').textContent = 'New Task';
        document.getElementById('taskId').value = '';
        document.getElementById('taskTitle').value = '';
        document.getElementById('taskDesc').value = '';
        document.getElementById('taskPriority').value = '2';
        document.getElementById('taskStatus').value = '0';
        document.getElementById('taskProject').value = '';
        const tomorrow = new Date(); tomorrow.setDate(tomorrow.getDate() + 1);
        document.getElementById('taskDueDate').value = tomorrow.toISOString().split('T')[0];
        document.getElementById('modalAlert').classList.add('d-none');
        bootstrap.Modal.getOrCreateInstance(document.getElementById('taskModal')).show();
    }

    const priorityMap = { Low: '1', Medium: '2', High: '3' };
    const statusMap   = { Pending: '0', InProgress: '1', Completed: '2' };

    function openEditModal(id) {
        const t = taskStore[id];
        if (!t) return;
        document.getElementById('modalTitle').textContent = 'Edit Task';
        document.getElementById('taskId').value = id;
        document.getElementById('taskTitle').value = t.title;
        document.getElementById('taskDesc').value = t.description || '';
        document.getElementById('taskPriority').value = priorityMap[t.priority] || '2';
        document.getElementById('taskStatus').value = statusMap[t.status] || '0';
        document.getElementById('taskDueDate').value = t.dueDate.split('T')[0];
        document.getElementById('taskProject').value = t.projectId || '';
        document.getElementById('modalAlert').classList.add('d-none');
        bootstrap.Modal.getOrCreateInstance(document.getElementById('taskModal')).show();
    }

    async function saveTask() {
        const btn     = document.getElementById('saveBtn');
        const spinner = document.getElementById('saveSpinner');
        const alertEl = document.getElementById('modalAlert');
        const id      = document.getElementById('taskId').value;

        btn.disabled = true;
        spinner.classList.remove('d-none');
        alertEl.classList.add('d-none');

        const projectId = document.getElementById('taskProject').value;
        const payload = {
            title:       document.getElementById('taskTitle').value,
            description: document.getElementById('taskDesc').value || null,
            priority:    parseInt(document.getElementById('taskPriority').value),
            status:      parseInt(document.getElementById('taskStatus').value),
            dueDate:     new Date(document.getElementById('taskDueDate').value).toISOString(),
            projectId:   projectId || null
        };

        try {
            const res = id
                ? await apiFetch(`/api/tasks/${id}`, { method: 'PUT',  body: JSON.stringify(payload) })
                : await apiFetch('/api/tasks',        { method: 'POST', body: JSON.stringify(payload) });

            const data = await res.json();
            if (data.success) {
                bootstrap.Modal.getInstance(document.getElementById('taskModal')).hide();
                loadTasks();
            } else {
                showFormErrors(alertEl, data);
            }
        } catch {
            alertEl.textContent = 'Network error.';
            alertEl.classList.remove('d-none');
        } finally {
            btn.disabled = false;
            spinner.classList.add('d-none');
        }
    }

    let deleteTargetId = null;
    function confirmDelete(id) {
        deleteTargetId = id;
        bootstrap.Modal.getOrCreateInstance(document.getElementById('deleteModal')).show();
    }

    document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
        if (!deleteTargetId) return;
        bootstrap.Modal.getOrCreateInstance(document.getElementById('deleteModal')).hide();
        const res = await apiFetch(`/api/tasks/${deleteTargetId}`, { method: 'DELETE' });
        if (res) await loadTasks();
        deleteTargetId = null;
    });

    loadProjects().then(() => loadTasks());
</script>
}
