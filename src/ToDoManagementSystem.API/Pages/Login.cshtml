@page
@model LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Taskco-TO-DO-Manager — Sign In</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --ga: #667eea;
            --gb: #764ba2;
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, var(--ga) 0%, var(--gb) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, system-ui, sans-serif;
            padding: 20px;
            position: relative;
            overflow: hidden;
        }

        /* Decorative background blobs */
        .blob {
            position: fixed;
            border-radius: 50%;
            background: rgba(255,255,255,.07);
            pointer-events: none;
            flex-shrink: 0;
        }
        .blob-1 { width: 420px; height: 420px; top: -100px; left: -120px; }
        .blob-2 { width: 320px; height: 320px; bottom: -60px; right: -80px; }
        .blob-3 { width: 180px; height: 180px; top: 42%; left: 58%; }

        /* ── Auth card ─────────────────────────────────── */
        .auth-card {
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 30px 70px rgba(0,0,0,.28);
            width: 100%;
            max-width: 420px;
            overflow: hidden;
            position: relative;
            z-index: 1;
        }

        /* ── Card header (gradient strip) ──────────────── */
        .auth-card-header {
            background: linear-gradient(135deg, var(--ga) 0%, var(--gb) 100%);
            padding: 28px 36px 24px;
            text-align: center;
        }

        .brand-icon {
            width: 52px; height: 52px;
            background: rgba(255,255,255,.2);
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: #fff;
            margin-bottom: 12px;
            box-shadow: 0 4px 14px rgba(0,0,0,.15);
        }

        .auth-card-header h5 {
            font-size: 17px;
            font-weight: 800;
            color: #fff;
            margin: 0 0 4px;
            letter-spacing: .2px;
        }

        .auth-card-header p {
            font-size: 12.5px;
            color: rgba(255,255,255,.78);
            margin: 0;
        }

        /* ── Card body ──────────────────────────────────── */
        .auth-card-body {
            padding: 24px 32px 28px;
        }

        /* ── Tab pills ──────────────────────────────────── */
        .auth-tabs {
            display: flex;
            background: #f3f4f6;
            border-radius: 10px;
            padding: 4px;
            gap: 4px;
            margin-bottom: 22px;
        }

        .auth-tab {
            flex: 1;
            border: none;
            background: transparent;
            border-radius: 7px;
            padding: .5rem 0;
            font-size: .88rem;
            font-weight: 700;
            color: #6b7280;
            cursor: pointer;
            transition: background .2s, color .2s, box-shadow .2s;
        }

        .auth-tab.active {
            background: linear-gradient(135deg, var(--ga), var(--gb));
            color: #fff;
            box-shadow: 0 2px 8px rgba(102,126,234,.35);
        }

        /* ── Inputs ─────────────────────────────────────── */
        .form-control {
            border-radius: 10px;
            border: 1.5px solid #e5e7eb;
            padding: .65rem 1rem;
            font-size: .93rem;
            transition: border-color .2s, box-shadow .2s;
            background: #fafafa;
        }

        .form-control:focus {
            border-color: var(--ga);
            box-shadow: 0 0 0 3px rgba(102,126,234,.13);
            background: #fff;
            outline: none;
        }

        .input-icon-wrap { position: relative; }

        .input-icon-wrap .bi {
            position: absolute;
            left: .9rem;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 1rem;
            pointer-events: none;
        }

        .input-icon-wrap .form-control { padding-left: 2.5rem; }

        .toggle-pw {
            position: absolute;
            right: .9rem;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #9ca3af;
            background: none;
            border: none;
            padding: 0;
            font-size: 1rem;
            transition: color .15s;
        }
        .toggle-pw:hover { color: var(--ga); }

        /* ── Form label ─────────────────────────────────── */
        .form-label {
            font-size: .8rem;
            font-weight: 700;
            color: #374151;
            margin-bottom: .4rem;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        /* ── Remember me ────────────────────────────────── */
        .form-check-input:checked {
            background-color: var(--ga);
            border-color: var(--ga);
        }
        .form-check-label { font-size: .85rem; color: #6b7280; }

        /* ── Password strength ──────────────────────────── */
        .pw-strength {
            height: 4px;
            border-radius: 2px;
            background: #e5e7eb;
            margin-top: 7px;
            overflow: hidden;
        }
        .pw-strength-bar {
            height: 100%;
            width: 0%;
            border-radius: 2px;
            transition: width .3s, background .3s;
        }
        .pw-strength-label {
            font-size: .75rem;
            margin-top: 4px;
            font-weight: 600;
            min-height: 16px;
        }

        /* ── Submit button ──────────────────────────────── */
        .btn-brand {
            background: linear-gradient(135deg, var(--ga) 0%, var(--gb) 100%);
            border: none;
            border-radius: 10px;
            color: #fff;
            font-weight: 700;
            padding: .72rem;
            font-size: .95rem;
            transition: opacity .2s, transform .1s, box-shadow .2s;
            box-shadow: 0 4px 14px rgba(102,126,234,.35);
        }

        .btn-brand:hover {
            color: #fff;
            opacity: .9;
            transform: translateY(-1px);
            box-shadow: 0 7px 22px rgba(102,126,234,.42);
        }

        .btn-brand:active  { transform: translateY(0); }
        .btn-brand:disabled {
            opacity: .55;
            transform: none;
            box-shadow: none;
        }

        /* ── Alert ──────────────────────────────────────── */
        .auth-alert {
            border-radius: 10px;
            font-size: .86rem;
            padding: .6rem 1rem;
        }

        /* ── Panel transition ───────────────────────────── */
        .auth-panel { display: none; }
        .auth-panel.active {
            display: block;
            animation: fadeUp .2s ease;
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(8px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── Divider ────────────────────────────────────── */
        .divider {
            display: flex;
            align-items: center;
            gap: .75rem;
            color: #d1d5db;
            font-size: .78rem;
            margin: 20px 0 16px;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e9ecef;
        }

        /* ── Footer link ────────────────────────────────── */
        .footer-link {
            color: var(--ga);
            text-decoration: none;
            font-weight: 700;
        }
        .footer-link:hover { color: var(--gb); text-decoration: underline; }

        .switch-hint { font-size: .85rem; color: #6b7280; text-align: center; }
    </style>
</head>
<body>
    <!-- Background blobs -->
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>

    <div class="auth-card">

        <!-- Gradient header -->
        <div class="auth-card-header">
            <div class="brand-icon mx-auto">
                <i class="bi bi-check2-square"></i>
            </div>
            <h5>Taskco-TO-DO-Manager</h5>
            <p>Stay organised. Get things done.</p>
        </div>

        <!-- Card body -->
        <div class="auth-card-body">

            <!-- Tab switcher -->
            <div class="auth-tabs">
                <button class="auth-tab active" id="tabLogin" onclick="switchTab('login')">Sign In</button>
                <button class="auth-tab" id="tabRegister" onclick="switchTab('register')">Create Account</button>
            </div>

            <!-- Shared alert -->
            <div id="authAlert" class="auth-alert alert d-none mb-3"></div>

            <!-- ── LOGIN PANEL ── -->
            <div class="auth-panel active" id="panelLogin">
                <form id="loginForm" novalidate>
                    <div class="mb-3">
                        <label class="form-label">Email address</label>
                        <div class="input-icon-wrap">
                            <i class="bi bi-envelope"></i>
                            <input type="email" class="form-control" id="loginEmail"
                                   placeholder="you@example.com" autocomplete="email" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <div class="input-icon-wrap">
                            <i class="bi bi-lock"></i>
                            <input type="password" class="form-control" id="loginPassword"
                                   placeholder="••••••••" autocomplete="current-password" required />
                            <button type="button" class="toggle-pw" onclick="togglePw('loginPassword', this)">
                                <i class="bi bi-eye-slash"></i>
                            </button>
                        </div>
                    </div>
                    <div class="mb-4 form-check">
                        <input type="checkbox" class="form-check-input" id="rememberMe" />
                        <label class="form-check-label" for="rememberMe">Remember me</label>
                    </div>
                    <button type="submit" class="btn btn-brand w-100" id="loginBtn">
                        <span id="loginSpinner" class="spinner-border spinner-border-sm d-none me-2"></span>
                        Sign In
                    </button>
                </form>
            </div>

            <!-- ── REGISTER PANEL ── -->
            <div class="auth-panel" id="panelRegister">
                <form id="registerForm" novalidate>
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <div class="input-icon-wrap">
                            <i class="bi bi-person"></i>
                            <input type="text" class="form-control" id="regName"
                                   placeholder="John Doe" autocomplete="name" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email address</label>
                        <div class="input-icon-wrap">
                            <i class="bi bi-envelope"></i>
                            <input type="email" class="form-control" id="regEmail"
                                   placeholder="you@example.com" autocomplete="email" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <div class="input-icon-wrap">
                            <i class="bi bi-lock"></i>
                            <input type="password" class="form-control" id="regPassword"
                                   placeholder="Min 8 chars, upper, lower, digit, special"
                                   autocomplete="new-password" oninput="checkStrength(this.value)" required />
                            <button type="button" class="toggle-pw" onclick="togglePw('regPassword', this)">
                                <i class="bi bi-eye-slash"></i>
                            </button>
                        </div>
                        <div class="pw-strength">
                            <div class="pw-strength-bar" id="strengthBar"></div>
                        </div>
                        <div class="pw-strength-label" id="strengthLabel"></div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Confirm Password</label>
                        <div class="input-icon-wrap">
                            <i class="bi bi-lock-fill"></i>
                            <input type="password" class="form-control" id="regConfirm"
                                   placeholder="••••••••" autocomplete="new-password" required />
                            <button type="button" class="toggle-pw" onclick="togglePw('regConfirm', this)">
                                <i class="bi bi-eye-slash"></i>
                            </button>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-brand w-100" id="registerBtn">
                        <span id="regSpinner" class="spinner-border spinner-border-sm d-none me-2"></span>
                        Create Account
                    </button>
                </form>
            </div>

            <div class="divider">or</div>

            <p class="switch-hint mb-0" id="switchHint">
                Don't have an account?
                <a class="footer-link" href="#" onclick="switchTab('register'); return false;">Register free</a>
            </p>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        if (localStorage.getItem('access_token')) window.location.href = '/dashboard';
        if (location.hash === '#register') switchTab('register');

        function switchTab(tab) {
            const isLogin = tab === 'login';
            document.getElementById('tabLogin').classList.toggle('active', isLogin);
            document.getElementById('tabRegister').classList.toggle('active', !isLogin);
            document.getElementById('panelLogin').classList.toggle('active', isLogin);
            document.getElementById('panelRegister').classList.toggle('active', !isLogin);
            hideAlert();
            document.getElementById('switchHint').innerHTML = isLogin
                ? `Don't have an account? <a class="footer-link" href="#" onclick="switchTab('register');return false;">Register free</a>`
                : `Already have an account? <a class="footer-link" href="#" onclick="switchTab('login');return false;">Sign in</a>`;
        }

        function showAlert(msg, type = 'danger') {
            const el = document.getElementById('authAlert');
            el.textContent = msg;
            el.className = `auth-alert alert alert-${type}`;
        }

        function showAlertList(msgs, type = 'danger') {
            const el = document.getElementById('authAlert');
            el.innerHTML = '';
            if (msgs.length === 1) {
                el.textContent = msgs[0];
            } else {
                const ul = document.createElement('ul');
                ul.style.cssText = 'margin:0;padding-left:1.2em';
                msgs.forEach(m => {
                    const li = document.createElement('li');
                    li.textContent = m;
                    ul.appendChild(li);
                });
                el.appendChild(ul);
            }
            el.className = `auth-alert alert alert-${type}`;
        }

        function hideAlert() {
            document.getElementById('authAlert').className = 'auth-alert alert d-none';
        }

        function togglePw(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon  = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye-slash';
            }
        }

        function checkStrength(pw) {
            const bar   = document.getElementById('strengthBar');
            const label = document.getElementById('strengthLabel');
            let score = 0;
            if (pw.length >= 8)          score++;
            if (/[A-Z]/.test(pw))        score++;
            if (/[0-9]/.test(pw))        score++;
            if (/[^A-Za-z0-9]/.test(pw)) score++;

            const levels = [
                { pct:   0, color: '#e5e7eb', text: '' },
                { pct:  25, color: '#ef4444', text: 'Weak' },
                { pct:  50, color: '#f97316', text: 'Fair' },
                { pct:  75, color: '#eab308', text: 'Good' },
                { pct: 100, color: '#22c55e', text: 'Strong' },
            ];
            const lvl = levels[score];
            bar.style.width      = lvl.pct + '%';
            bar.style.background = lvl.color;
            label.textContent    = lvl.text;
            label.style.color    = lvl.color;
        }

        document.getElementById('loginForm').addEventListener('submit', async e => {
            e.preventDefault();
            const btn     = document.getElementById('loginBtn');
            const spinner = document.getElementById('loginSpinner');
            btn.disabled = true;
            spinner.classList.remove('d-none');
            hideAlert();

            try {
                const res = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        email:    document.getElementById('loginEmail').value.trim(),
                        password: document.getElementById('loginPassword').value
                    })
                });
                const data = await res.json();
                if (data.success) {
                    localStorage.setItem('access_token',  data.data.accessToken);
                    localStorage.setItem('refresh_token', data.data.refreshToken);
                    localStorage.setItem('user_info', JSON.stringify({
                        fullName: data.data.fullName,
                        email:    data.data.email,
                        role:     data.data.role
                    }));
                    window.location.href = '/dashboard';
                } else {
                    showAlert(data.message || 'Invalid email or password.');
                }
            } catch {
                showAlert('Network error. Please try again.');
            } finally {
                btn.disabled = false;
                spinner.classList.add('d-none');
            }
        });

        document.getElementById('registerForm').addEventListener('submit', async e => {
            e.preventDefault();
            hideAlert();

            const name    = document.getElementById('regName').value.trim();
            const email   = document.getElementById('regEmail').value.trim();
            const pw      = document.getElementById('regPassword').value;
            const confirm = document.getElementById('regConfirm').value;

            if (pw !== confirm) { showAlert('Passwords do not match.'); return; }

            const btn     = document.getElementById('registerBtn');
            const spinner = document.getElementById('regSpinner');
            btn.disabled = true;
            spinner.classList.remove('d-none');

            try {
                const res = await fetch('/api/auth/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fullName: name, email, password: pw })
                });
                const data = await res.json();
                if (data.success) {
                    localStorage.setItem('access_token',  data.data.accessToken);
                    localStorage.setItem('refresh_token', data.data.refreshToken);
                    localStorage.setItem('user_info', JSON.stringify({
                        fullName: data.data.fullName,
                        email:    data.data.email,
                        role:     data.data.role
                    }));
                    window.location.href = '/dashboard';
                } else {
                    const msgs = data.errors?.length ? data.errors : [data.message || 'Registration failed.'];
                    showAlertList(msgs);
                }
            } catch {
                showAlert('Network error. Please try again.');
            } finally {
                btn.disabled = false;
                spinner.classList.add('d-none');
            }
        });
    </script>
</body>
</html>
