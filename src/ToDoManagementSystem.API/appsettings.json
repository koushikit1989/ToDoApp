{
  "ConnectionStrings": {
    "DefaultConnection": "Server=192.168.1.253;Database=TODOAppDB;User Id=sa;Password=ica@12345;MultipleActiveResultSets=true;TrustServerCertificate=true;"
  },
  "Jwt": {
    "Key": "YourSuperSecretKeyWith32PlusCharsHere!",
    "Issuer": "ToDoManagementSystem",
    "Audience": "ToDoManagementSystemUsers",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Hangfire": {
    "DashboardPath": "/hangfire",
    "ReminderJobCronExpression": "0 * * * *"
  },
  "Email": {
    "SmtpHost": "smtp.example.com",
    "SmtpPort": "587",
    "SenderName": "To-Do Management System",
    "SenderEmail": "noreply@todo.example.com",
    "SmtpUser": "",
    "SmtpPassword": ""
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "AllowedHosts": "*"
}
